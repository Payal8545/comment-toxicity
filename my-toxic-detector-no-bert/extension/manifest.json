{
  "manifest_version": 3,
  "name": "Toxic Blur (No BERT)",
  "version": "1.0",
  "description": "Blurs toxic text using a local server (HateSonar + profanity list, no BERT).",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["http://127.0.0.1:8001/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
